# =============================================================================
# LOCAL DEVELOPMENT (default)
# Point at a locally-running dynalite emulator.
# Run `npm run db:start` to launch it.
# =============================================================================
DDB_ENDPOINT=http://127.0.0.1:8000
DDB_PORT=8000
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
DDB_TABLE_PREFIX=playground_

# =============================================================================
# AWS CLOUD (real DynamoDB)
# Comment out or remove the local settings above and configure AWS credentials
# via one of the standard methods:
#
#   Option A — environment variables:
#     AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
#     AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
#     AWS_REGION=eu-west-2
#
#   Option B — profile in ~/.aws/credentials:
#     [default]
#     aws_access_key_id = AKIAIOSFODNN7EXAMPLE
#     aws_secret_access_key = wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
#
#   Option C — IAM role (EC2, ECS, Lambda)
#
# Then use ONLY these vars in .env (no DDB_ENDPOINT = cloud):
#   AWS_REGION=eu-west-2
#   DDB_TABLE_PREFIX=playground_
# =============================================================================
