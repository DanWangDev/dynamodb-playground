{
  "name": "dynamodb-playground",
  "version": "1.0.0",
  "private": true,
  "description": "Hands-on DynamoDB learning playground — concept explanations followed by practical exercises",
  "scripts": {
    "db:start": "npx tsx scripts/start-db.ts",
    "db:docker": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "setup": "npx tsx scripts/setup-tables.ts",
    "seed": "npx tsx scripts/seed-data.ts",
    "teardown": "npx tsx scripts/teardown-tables.ts",
    "reset": "npx tsx scripts/teardown-tables.ts && npx tsx scripts/setup-tables.ts && npx tsx scripts/seed-data.ts",
    "db:scan": "npx tsx scripts/scan-data.ts",
    "exercise:crud": "npx tsx src/01-crud/exercise.ts",
    "exercise:queries": "npx tsx src/02-queries/exercise.ts",
    "exercise:indexes": "npx tsx src/03-indexes/exercise.ts",
    "exercise:single-table": "npx tsx src/04-single-table/exercise.ts",
    "exercise:advanced": "npx tsx src/05-advanced/exercise.ts",
    "exercise:streams": "npx tsx src/06-streams/exercise.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-dynamodb-streams": "^3.1060.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^1.6.0",
    "dynalite": "^4.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
